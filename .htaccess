# Axon main site SEO-safe launch rules
Options -Indexes
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Force main Singapore host
RewriteCond %{HTTP_HOST} ^www\.axon\.com\.sg$ [NC]
RewriteRule ^ https://axon.com.sg%{REQUEST_URI} [R=301,L]

# Preserve old indexed URLs by redirecting to new relevant pages
Redirect 301 /about-us.html /about-axon.html
Redirect 301 /about.html /about-axon.html
Redirect 301 /contact-us.html /contact.html
Redirect 301 /services.html /index.html#services
Redirect 301 /web-design.html /corporate-websites.html
Redirect 301 /website-design.html /corporate-websites.html
Redirect 301 /web-development.html /business-applications.html
Redirect 301 /website-maintenance.html /website-maintenance-support.html
Redirect 301 /ecommerce.html /e-commerce-solutions.html
Redirect 301 /e-commerce.html /e-commerce-solutions.html
Redirect 301 /hosting.html /corporate-hosting.html
Redirect 301 /domain.html /domain-registration-management.html
Redirect 301 /email-hosting.html /business-email-hosting.html
Redirect 301 /google-workspace.html /google-workspace-solutions.html
Redirect 301 /microsoft-365.html /microsoft-365-solutions.html
Redirect 301 /office-365.html /microsoft-365-solutions.html
Redirect 301 /seo.html /seo-local-visibility.html
Redirect 301 /malware.html /malware-removal.html
Redirect 301 /backup.html /backup-disaster-recovery.html
Redirect 301 /ai.html /ai-consulting-implementation.html
Redirect 301 /automation.html /business-process-automation.html
Redirect 301 /chatbot.html /website-ai-chatbot.html
Redirect 301 /blog.html /trending/
Redirect 301 /news.html /trending/

# Custom 404 fallback
ErrorDocument 404 /404.html